{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "outDir": "./",
    "rootDir": "./",
    "declaration": true,
    "declarationMap": true
  },
  "include": ["server/src/**/*"],
  "exclude": ["node_modules"]
}